{
  "name": "junction/api",
  "description": "Junction API Application",
  "type": "project",
  "license": "MIT",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/JunctionIO/cli.git"
    }
  ],
  "require": {
    "php": "^8.4",
    "firebase/php-jwt": "^7.1",
    "meritum/bus-module": "^1.0",
    "meritum/database": "^1.2",
    "meritum/http": "^1.2",
    "meritum/http-exception-handler": "^1.1",
    "meritum/logger": "^1.0",
    "meritum/serialization": "^1.0",
    "meritum/structured-logging": "^1.0",
    "meritum/validation": "^1.0",
    "php-amqplib/php-amqplib": "^3.7"
  },
  "require-dev": {
    "bnf/phpstan-psr-container": "^1.0",
    "fakerphp/faker": "^1.24",
    "junction/cli": "^0.1",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "meritum/testing": "^0.1",
    "meritum/model-factory": "^0.1",
    "meritum/http-testing": "^0.1"
  },
  "autoload": {
    "psr-4": {
      "Junction\\Api\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Junction\\Api\\Test\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": [
      "vendor/bin/phpunit"
    ],
    "test:unit": [
      "vendor/bin/phpunit --testsuite=Unit"
    ],
    "test:integration": [
      "vendor/bin/phpunit --testsuite=Integration"
    ],
    "analyze": [
      "vendor/bin/phpstan analyze src --memory-limit=-1"
    ]
  }
}
